/etc/init.d/networking restart
/etc/init.d/quagga restart

ip route add 100.0.0.0/24 via 200.0.0.6

iptables -t nat -A PREROUTING -p tcp --dport 1194 -j DNAT --to-destination 192.168.0.100:7000
iptables -A FORWARD -p tcp -d 192.168.0.100 --dport 7000 -j ACCEPT

iptables -t nat -A POSTROUTING -s 192.168.0.0/24 -o eth0 -j MASQUERADE
iptables -t nat -A POSTROUTING -s 192.168.0.0/24 -o eth1 -j MASQUERADE
iptables -t nat -A POSTROUTING -s 192.168.0.0/24 -o eth2 -j MASQUERADE

# Allow traffic that is already ESTABLISHED (can be omitted because the policy is ACCEPT)
iptables -A FORWARD -m state --state RELATED,ESTABLISHED -j ACCEPT
# Drop new incoming connections to private subnet
iptables -A FORWARD -d 192.168.0.0/24 -m state --state NEW -j DROP
