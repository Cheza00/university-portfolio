/etc/init.d/networking restart

ip route add default via 100.0.0.9

iptables -t nat -A POSTROUTING -s 192.168.0.0/24 -o eth1 -j MASQUERADE
iptables -t nat -A POSTROUTING -s 192.168.0.0/24 -o eth2 -j MASQUERADE
iptables -t nat -A POSTROUTING -s 192.168.0.0/24 -o eth3 -j MASQUERADE

# As per point 7, I permitted traffic specifically to/from the private subnet, not general ssh traffic from and to whatever host 
iptables -A FORWARD -d 192.168.0.0/24 -p tcp --dport 22 -j ACCEPT
iptables -A FORWARD -s 192.168.0.0/24 -p tcp --dport 22 -j ACCEPT
iptables -A FORWARD -d 192.168.0.0/24 -p tcp --dport 1194 -j ACCEPT
iptables -A FORWARD -s 192.168.0.0/24 -p tcp --dport 1194 -j ACCEPT
iptables -A FORWARD -m state --state RELATED,ESTABLISHED -j ACCEPT

# block the forward traffic TO and FROM the private subnet. The forward traffic between the other nodes can be forwarded through this router
iptables -A FORWARD -d 192.168.0.0/24 -j DROP
iptables -A FORWARD -s 192.168.0.0/24 -j DROP

# The following lines are the iptables rules for point 6, then commented out to comply to point 7 requested policy

# Allow traffic that is already ESTABLISHED (can be omitted because the policy is ACCEPT)
#iptables -A FORWARD -m state --state RELATED,ESTABLISHED -j ACCEPT
# Drop new incoming connections to private subnet
#iptables -A FORWARD -d 192.168.0.0/24 -m state --state NEW -j DROP
