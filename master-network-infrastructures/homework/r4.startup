/etc/init.d/networking restart

ip route add default via 100.0.0.8

systemctl start frr

iptables -A FORWARD -p tcp --dport 22 -j ACCEPT
iptables -A FORWARD -m state --state RELATED,ESTABLISHED -j ACCEPT

# I change the default policy for the forwarded traffic to DROP, to block everything not explicitly allowed
iptables -P FORWARD DROP
